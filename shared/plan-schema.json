{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionPlan",
  "description": "Schema for Excel AI Copilot execution plans. Shared between frontend and backend.",
  "type": "object",
  "required": ["planId", "createdAt", "userRequest", "summary", "steps", "preserveFormatting", "confidence"],
  "properties": {
    "planId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique plan identifier"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of plan creation"
    },
    "userRequest": {
      "type": "string",
      "description": "Original natural-language user request"
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of the plan"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/PlanStep" }
    },
    "preserveFormatting": {
      "type": "boolean",
      "default": true,
      "description": "Whether to preserve existing workbook formatting"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Planner confidence in the plan (0-1)"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional warnings from the planner"
    }
  },
  "definitions": {
    "StepAction": {
      "type": "string",
      "enum": [
        "readRange", "writeValues", "writeFormula",
        "matchRecords", "groupSum",
        "createTable", "applyFilter", "sortRange",
        "createPivot", "createChart",
        "addConditionalFormat",
        "cleanupText", "removeDuplicates",
        "freezePanes", "findReplace",
        "addValidation",
        "addSheet", "renameSheet", "deleteSheet", "copySheet", "protectSheet",
        "autoFitColumns", "mergeCells", "setNumberFormat"
      ]
    },
    "PlanStep": {
      "type": "object",
      "required": ["id", "description", "action", "params"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique step ID within the plan"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable step description"
        },
        "action": { "$ref": "#/definitions/StepAction" },
        "params": {
          "type": "object",
          "description": "Action-specific parameters"
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of steps that must complete before this one"
        }
      }
    }
  }
}
