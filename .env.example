# ═══════════════════════════════════════════════════════════════════════════════
# Excel AI Copilot — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real secrets.
#
# For LOCAL DEV:  only LLM_MODEL + LLM_BASE_URL are needed (+ LLM_API_KEY if cloud).
# For DOCKER:     also set FRONTEND_URL before building.
# For OPENSHIFT:  inject via Secrets + ConfigMaps (not a .env file).
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (required) ───────────────────────────────────────────────────
# LiteLLM model string.  Uncomment ONE block below.
#
# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...
#
# ── OpenAI ───────────────────────────────────────────────────────────────────
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
#
# ── Google Gemini ────────────────────────────────────────────────────────────
# LLM_MODEL=gemini/gemini-1.5-pro
# LLM_API_KEY=AIza...
#
# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# LLM_MODEL=azure/<your-deployment-name>
# LLM_API_KEY=<azure-api-key>
# LLM_BASE_URL=https://<your-resource>.openai.azure.com/
# LLM_API_VERSION=2024-02-01
#
# ── Ollama (local, no API key needed) ────────────────────────────────────────
# LLM_MODEL=ollama/qwen3:27b
# LLM_BASE_URL=http://localhost:11434
# LLM_JSON_MODE=true
#
# ── Cohere (Command R) ──────────────────────────────────────────────────────
# LLM_MODEL=command-r-plus
# LLM_API_KEY=<cohere-api-key>
# LLM_JSON_MODE=true
#
# ── LiteLLM proxy / any OpenAI-compatible endpoint ──────────────────────────
# LLM_MODEL=openai/<model-name>
# LLM_BASE_URL=http://my-litellm-proxy:4000
# LLM_API_KEY=<proxy-key-if-required>
#
# ── AWS Bedrock ──────────────────────────────────────────────────────────────
# LLM_MODEL=bedrock/anthropic.claude-3-sonnet-20240229-v1:0
# (uses AWS credentials from environment / ~/.aws/credentials)

# ─────────────────────────────────────────────────────────────────────────────
# ACTIVE CONFIGURATION  (edit these lines)
# ─────────────────────────────────────────────────────────────────────────────

LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_VERSION=

# ── Generation parameters ─────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Force JSON output mode. Recommended for Qwen, Cohere, and smaller Ollama models.
# Not needed for Claude, GPT-4o, or other strong instruction-following models.
LLM_JSON_MODE=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["https://localhost:3000","https://localhost:3001"]

# ── Deployment mode ───────────────────────────────────────────────────────────
OPENSHIFT=false
SERVE_STATIC=false
STATIC_DIR=./static

# ── Docker build args (not runtime — set before `docker build`) ───────────────
# Public HTTPS URL baked into manifest.xml at build time.
FRONTEND_URL=https://localhost:3000
