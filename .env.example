# ═══════════════════════════════════════════════════════════════════════════════
# Excel AI Copilot — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real secrets.
#
# For LOCAL DEV:  only LLM_MODEL + LLM_API_KEY are needed.
# For DOCKER:     also set FRONTEND_URL before building.
# For OPENSHIFT:  inject via Secrets + ConfigMaps (not a .env file).
#
# Uses the OpenAI SDK — any OpenAI-compatible provider works.
# Provider is auto-detected from the model prefix or LLM_BASE_URL.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (required) ───────────────────────────────────────────────────
# Model string.  Uncomment ONE block below.
#
# ── OpenAI (direct) ─────────────────────────────────────────────────────────
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
#
# ── Google Gemini (via OpenAI-compatible API) ────────────────────────────────
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=AIza...
# (base URL is auto-detected from the "gemini/" prefix)
#
# ── Anthropic (Claude) — requires OpenAI-compatible proxy ───────────────────
# Option 1: Use a LiteLLM proxy or OpenRouter
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-or-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
#
# Option 2: Use anthropic-openai-adapter or similar
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=http://localhost:4000/v1
#
# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# LLM_MODEL=gpt-4o
# LLM_API_KEY=<azure-api-key>
# LLM_BASE_URL=https://<your-resource>.openai.azure.com/
# LLM_API_VERSION=2024-02-01
#
# ── Ollama (local, no API key needed) ────────────────────────────────────────
# LLM_MODEL=ollama/qwen3:27b
# LLM_BASE_URL=http://localhost:11434
# LLM_JSON_MODE=true
#
# ── Any OpenAI-compatible endpoint ──────────────────────────────────────────
# LLM_MODEL=<model-name>
# LLM_BASE_URL=http://my-proxy:4000/v1
# LLM_API_KEY=<key-if-required>

# ─────────────────────────────────────────────────────────────────────────────
# ACTIVE CONFIGURATION  (edit these lines)
# ─────────────────────────────────────────────────────────────────────────────

LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_VERSION=

# ── Generation parameters ─────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Force JSON output mode. Recommended for Qwen, Cohere, and smaller Ollama models.
# Not needed for GPT-4o, Gemini, or other strong instruction-following models.
LLM_JSON_MODE=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["https://localhost:3000","https://localhost:3001"]

# ── Deployment mode ───────────────────────────────────────────────────────────
OPENSHIFT=false
SERVE_STATIC=false
STATIC_DIR=./static

# ── Docker build args (not runtime — set before `docker build`) ───────────────
# Public HTTPS URL baked into manifest.xml at build time.
FRONTEND_URL=https://localhost:3000
