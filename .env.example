# ═══════════════════════════════════════════════════════════════════════════════
# AI Assistant For Excel — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real secrets.
#
# For LOCAL DEV:  only LLM_MODEL + LLM_API_KEY are needed.
# For DOCKER:     also set FRONTEND_URL before building.
# For OPENSHIFT:  inject via Secrets + ConfigMaps (not a .env file).
#
# Uses the OpenAI SDK — any OpenAI-compatible provider works.
# Provider is auto-detected from the model prefix or LLM_BASE_URL.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (required) ───────────────────────────────────────────────────
# Model string.  Uncomment ONE block below.
#
# ── OpenAI (direct) ─────────────────────────────────────────────────────────
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
#
# ── Google Gemini (via OpenAI-compatible API) ────────────────────────────────
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=AIza...
# (base URL is auto-detected from the "gemini/" prefix)
#
# ── Anthropic (Claude) — native OpenAI-compatible endpoint ──────────────────
# LLM_MODEL=anthropic/claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...
# (base URL is auto-detected from the "anthropic/" prefix)
#
# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# LLM_MODEL=gpt-4o
# LLM_API_KEY=<azure-api-key>
# LLM_BASE_URL=https://<your-resource>.openai.azure.com/
# LLM_API_VERSION=2024-02-01
#
# ── Ollama (local, no API key needed) ────────────────────────────────────────
# LLM_MODEL=ollama/qwen2.5:14b-instruct
# LLM_BASE_URL=http://localhost:11434
# LLM_JSON_MODE=true
#
# ── Ollama Cloud (API key required) ──────────────────────────────────────────
# LLM_MODEL=ollama/deepseek-v3.1:671b-cloud
# LLM_BASE_URL=https://ollama.com
# LLM_API_KEY=your-ollama-api-key
#
# ── Cohere ───────────────────────────────────────────────────────────────────
# LLM_MODEL=cohere/command-a-03-2025
# LLM_API_KEY=your-cohere-key
#
# ── Any OpenAI-compatible endpoint ──────────────────────────────────────────
# LLM_MODEL=<model-name>
# LLM_BASE_URL=http://my-proxy:4000/v1
# LLM_API_KEY=<key-if-required>

# ─────────────────────────────────────────────────────────────────────────────
# ACTIVE CONFIGURATION  (edit these lines)
# ─────────────────────────────────────────────────────────────────────────────

LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_VERSION=

# ── Generation parameters ─────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Force JSON output mode. Recommended for Qwen, Cohere, and smaller Ollama models.
# Not needed for GPT-4o, Gemini, or other strong instruction-following models.
LLM_JSON_MODE=false

# ── Embedding / Capability Search ────────────────────────────────────────────
# Sentence-transformers model for semantic search. Bundled in backend/models/.
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# How many capabilities / few-shot examples to retrieve per query.
CAPABILITY_TOP_K=10
FEW_SHOT_TOP_K=5

# ── Data paths (auto-resolved if empty — usually no need to change) ──────────
# CHROMA_PERSIST_DIR=        # default: backend/data/chroma/
# FEEDBACK_DB_PATH=          # default: backend/data/feedback.db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["https://localhost:3000","https://localhost:3001"]

# ── Deployment mode ───────────────────────────────────────────────────────────
OPENSHIFT=false
SERVE_STATIC=false
STATIC_DIR=./static

# ── Air-gap / telemetry ──────────────────────────────────────────────────────
# Already disabled in code, but set here for belt-and-suspenders.
ANONYMIZED_TELEMETRY=False
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ── Docker build args (not runtime — set before `docker build`) ───────────────
# Public HTTPS URL baked into manifest.xml at build time.
# FRONTEND_URL=https://localhost:3000
# For air-gapped: also set OFFICE_JS_SRC=/assets/office.js (see AIRGAP.md)
# OFFICE_JS_SRC=
