# ═══════════════════════════════════════════════════════════════════════════════
# Excel AI Copilot — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real secrets.
#
# For LOCAL DEV:  only LLM_MODEL + LLM_API_KEY are needed.
# For DOCKER:     also set FRONTEND_URL before building.
# For OPENSHIFT:  inject via Secrets + ConfigMaps (not a .env file).
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (required) ───────────────────────────────────────────────────
# LiteLLM model string.  Examples:
#   OpenAI:     gpt-4o | gpt-4-turbo | gpt-3.5-turbo
#   Anthropic:  claude-sonnet-4-20250514 | claude-opus-4-20250514
#   Ollama:     ollama/llama3 | ollama/mistral  (set LLM_BASE_URL too)
#   Azure:      azure/<your-deployment-name>    (set LLM_BASE_URL + LLM_API_VERSION)
LLM_MODEL=claude-sonnet-4-20250514

# API key for the chosen provider.
# Leave empty for local models like Ollama (no key needed).
LLM_API_KEY=

# Optional: custom API base URL.
#   Ollama local:  http://localhost:11434
#   LiteLLM proxy: http://my-proxy:4000
#   Azure:         https://<resource>.openai.azure.com/
LLM_BASE_URL=

# Optional: API version for Azure OpenAI only
LLM_API_VERSION=

# ── Generation parameters ─────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── Server ────────────────────────────────────────────────────────────────────
# Port the backend listens on.
# Local dev default: 8000   |   Docker/OpenShift default: 8080
PORT=8000

# Set to false in production
DEBUG=true

# ── Deployment mode ───────────────────────────────────────────────────────────
# Set OPENSHIFT=true to enable production mode:
#   - Serves built frontend from STATIC_DIR
#   - Disables debug/reload
#   - Opens CORS to all origins (TLS terminated at the Route)
OPENSHIFT=false

# Serve the built frontend (dist/) from this FastAPI process.
# Automatically true when OPENSHIFT=true.
# Set manually to true if you want static serving without the rest of OpenShift mode.
SERVE_STATIC=false

# Path to the built frontend files (output of `npm run build`).
STATIC_DIR=./static

# ── Docker build args (not runtime — set before `docker build` or in docker-compose) ──
# The public HTTPS URL where the add-in will be accessible.
# Gets baked into manifest.xml at build time.
# Local Docker test:  https://localhost:8080
# OpenShift:          https://excel-copilot.apps.your-cluster.example.com
FRONTEND_URL=https://localhost:3000
