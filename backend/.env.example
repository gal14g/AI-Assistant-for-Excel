# Excel AI Copilot – Backend Environment Variables
# Copy this file to .env and fill in the values for your chosen provider.
# LiteLLM is used as the LLM abstraction layer, so any provider it supports works here.

# ─────────────────────────────────────────────────────────────────────────────
# PROVIDER EXAMPLES  (uncomment the block for your provider, comment the rest)
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# ── Google Gemini ─────────────────────────────────────────────────────────────
# LLM_MODEL=gemini/gemini-1.5-pro
# LLM_API_KEY=AIza...

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# LLM_MODEL=azure/<your-deployment-name>
# LLM_API_KEY=<azure-api-key>
# LLM_BASE_URL=https://<your-resource>.openai.azure.com/
# LLM_API_VERSION=2024-02-01

# ── Ollama (local, no API key needed) ─────────────────────────────────────────
# LLM_MODEL=ollama/llama3
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=

# ── LiteLLM proxy / any OpenAI-compatible endpoint ───────────────────────────
# LLM_MODEL=openai/<model-name>
# LLM_BASE_URL=http://my-litellm-proxy:4000
# LLM_API_KEY=<proxy-key-if-required>

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# LLM_MODEL=bedrock/anthropic.claude-3-sonnet-20240229-v1:0
# (uses AWS credentials from environment / ~/.aws/credentials, no LLM_API_KEY needed)

# ─────────────────────────────────────────────────────────────────────────────
# ACTIVE CONFIGURATION  (edit these lines)
# ─────────────────────────────────────────────────────────────────────────────

LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_VERSION=

# Generation parameters
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["https://localhost:3000","https://localhost:3001"]
